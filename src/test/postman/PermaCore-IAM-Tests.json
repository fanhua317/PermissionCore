{
  "info": {
    "name": "PermaCore IAM API Tests",
    "description": "PermaCore IAM RBAC3 smoke tests: auth, session role switching, refresh, user/role search, SoD CRUD.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('login success', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.expect(body.code).to.equal(200);",
              "pm.expect(body.data).to.have.property('accessToken');",
              "pm.expect(body.data).to.have.property('refreshToken');",
              "pm.expect(body.data).to.have.property('activeRoleIds');",
              "pm.expect(body.data).to.have.property('effectiveRoleIds');",
              "pm.expect(body.data).to.have.property('permissions');",
              "pm.expect(body.data).to.have.property('roles');",
              "pm.environment.set('accessToken', body.data.accessToken);",
              "pm.environment.set('refreshToken', body.data.refreshToken);",
              "pm.environment.set('tokenType', body.data.tokenType || 'Bearer');",
              "if (body.data.activeRoleIds && body.data.activeRoleIds.length) { pm.environment.set('firstActiveRoleId', body.data.activeRoleIds[0]); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "2. Get Session Roles",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('session roles success', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.expect(body.data).to.have.property('roles');",
              "pm.expect(body.data).to.have.property('activeRoleIds');",
              "pm.expect(body.data).to.have.property('effectiveRoleIds');",
              "pm.expect(body.data).to.have.property('permissions');"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "{{tokenType}} {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/auth/session-roles",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "session-roles"]
        }
      },
      "response": []
    },
    {
      "name": "3. Switch Session Roles",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('switch success', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.expect(body.data).to.have.property('accessToken');",
              "pm.expect(body.data).to.have.property('activeRoleIds');",
              "pm.environment.set('accessToken', body.data.accessToken);",
              "pm.environment.set('refreshToken', body.data.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "{{tokenType}} {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"activeRoleIds\": [{{firstActiveRoleId}}]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/session-roles",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "session-roles"]
        }
      },
      "response": []
    },
    {
      "name": "4. Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('refresh success', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.expect(body.data).to.have.property('accessToken');",
              "pm.expect(body.data).to.have.property('activeRoleIds');",
              "pm.environment.set('accessToken', body.data.accessToken);",
              "pm.environment.set('refreshToken', body.data.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh"]
        }
      },
      "response": []
    },
    {
      "name": "5. User Search",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "{{tokenType}} {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/user/page?pageNo=1&pageSize=10&username=admin&nickname=admin",
          "host": ["{{baseUrl}}"],
          "path": ["api", "user", "page"],
          "query": [
            { "key": "pageNo", "value": "1" },
            { "key": "pageSize", "value": "10" },
            { "key": "username", "value": "admin" },
            { "key": "nickname", "value": "admin" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "6. Role Search",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "{{tokenType}} {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/role/page?pageNo=1&pageSize=10&roleName=管理员",
          "host": ["{{baseUrl}}"],
          "path": ["api", "role", "page"],
          "query": [
            { "key": "pageNo", "value": "1" },
            { "key": "pageSize", "value": "10" },
            { "key": "roleName", "value": "管理员" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "7. SoD List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "{{tokenType}} {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/sod-constraint/page?pageNo=1&pageSize=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "sod-constraint", "page"],
          "query": [
            { "key": "pageNo", "value": "1" },
            { "key": "pageSize", "value": "10" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "8. Logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "{{tokenType}} {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "logout"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:54321", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "tokenType", "value": "Bearer", "type": "string" },
    { "key": "firstActiveRoleId", "value": "", "type": "string" }
  ]
}
