# Copy this file to .env. Keep secret values empty until you set them locally.
MYSQL_ROOT_PASSWORD=
# 16-128 characters; used only by the restricted permacore_app account.
MYSQL_APP_PASSWORD=
REDIS_PASSWORD=
JWT_SECRET=

# Bootstrap is disabled by default. ADMIN_INITIAL_PASSWORD is required only
# when APP_BOOTSTRAP_ENABLED=true; the application enforces the 8-72 limit.
APP_BOOTSTRAP_ENABLED=false
ADMIN_INITIAL_PASSWORD=
PUBLIC_API_DOCS=false

# Optional: point these to reviewed mirror/offline tags. Omit them to use the
# pinned official defaults in docker-compose.yml.
# MYSQL_IMAGE=registry.example.com/library/mysql:8.0.46
# REDIS_IMAGE=registry.example.com/library/redis:7.4.7-alpine3.21
# MAVEN_IMAGE=registry.example.com/library/maven:3.9.16-eclipse-temurin-21-alpine
# JRE_IMAGE=registry.example.com/library/eclipse-temurin:21-jre-alpine-3.23
# NODE_IMAGE=registry.example.com/library/node:22.23.1-alpine3.24
# NGINX_IMAGE=registry.example.com/library/nginx:1.30.3-alpine
